<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>PCScreen-Windows-Agent</AssemblyName>
    <RootNamespace>PCScreen.WindowsAgent</RootNamespace>
    <Version>1.5.0</Version>
    <Authors>Nguyễn Tiến Thành</Authors>
    <Company>Nguyễn Tiến Thành / TienThanhDEV</Company>
    <Copyright>Copyright © 2026 Nguyễn Tiến Thành</Copyright>
    <RepositoryUrl>https://github.com/TienThanhDEV/Screen-Tunring-PC-ESP32s3</RepositoryUrl>
    <Product>PCScreen Windows Agent</Product>
    <Description>Send Windows hardware telemetry to PCScreen ESP32-S3 over USB CDC.</Description>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\pcscreen.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="LibreHardwareMonitorLib" Version="0.9.6" />
  </ItemGroup>
</Project>
